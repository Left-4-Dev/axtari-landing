---
import BenefitsContent from "@components/sections/benefits/BenefitsContent.astro";
---

<section class="benefits section">
  <div class="benefits__container container">
    <BenefitsContent />
  </div>
</section>

<style>
  

  .benefits {
    --benefits-bg: #f6f4f8;
    --benefits-surface: rgba(255, 255, 255, 0.42);
    --benefits-surface-strong: rgba(255, 255, 255, 0.72);
    --benefits-border: rgba(124, 130, 255, 0.14);
    --benefits-title: #1f2433;
    --benefits-text: #40475a;
    --benefits-text-soft: #6a7186;
    --benefits-track: #76809a;
    --benefits-shadow-lg: 0 30px 80px rgba(75, 82, 139, 0.14);
    --benefits-shadow-md: 10px 10px 10px rgba(88, 93, 147, 0.4);
    --benefits-shadow-sm: 0 10px 24px rgba(88, 93, 147, 0.1);
    --benefits-accent-1: #8fc6ff;
    --benefits-accent-2: #8f9cff;
    --benefits-accent-3: #8f84ff;
    --benefits-accent-4: #7a6dff;

    --padding-section: 4rem 0;
    background:
      radial-gradient(
        circle at 15% 18%,
        rgba(151, 198, 255, 0.28),
        transparent 26%
      ),
      radial-gradient(
        circle at 85% 12%,
        rgba(143, 132, 255, 0.18),
        transparent 24%
      ),
      radial-gradient(
        circle at 50% 100%,
        rgba(140, 120, 255, 0.12),
        transparent 30%
      ),
      linear-gradient(180deg, #f8f7fb 0%, #f3f1f7 100%);
    text-transform: uppercase;
  }

  .benefits__container {
    --max-width-container: 1200px;
  }

  /* =========================
   LARGE DESKTOP (<= 1240px)
========================= */
  @media (max-width: 1240px) {
    .benefits {
      --padding-section-xl: 4rem 28px;
      --max-width-container-xl: 1120px;
    }
  }

  /* =========================
   LAPTOP (<= 1024px)
========================= */
  @media (max-width: 1024px) {
    .benefits {
      --padding-section-lg: 3.5rem 32px;
      --max-width-container-lg: 1000px;
    }
  }

  /* =========================
   TABLET (<= 900px)
========================= */
  @media (max-width: 900px) {
    .benefits {
      --padding-section-md: 3.25rem 36px;
    }
  }

  /* =========================
   MOBILE (<= 640px)
========================= */
  @media (max-width: 640px) {
    .benefits {
      --padding-section-sm: 3rem 28px;
    }
  }

  /* =========================
   SMALL MOBILE (<= 380px)
========================= */
  @media (max-width: 380px) {
    .benefits {
      --padding-section-xs: 2.75rem 20px;
    }
  }
</style>

<script>
  import { gsap, ScrollTrigger } from "@lib/animations/gsap.setup";


  const initBenefitsSectionEntrance = (): void => {
    const section = document.querySelector<HTMLElement>(".benefits");
    if (!section) return;

    const eyebrow = section.querySelector<HTMLElement>(".eyebrow");
    const title = section.querySelector<HTMLElement>(".benefits__title");
    const description = section.querySelector<HTMLElement>(
      ".benefits__description",
    );
    const grid = section.querySelector<HTMLElement>(".benefits__grid");
    const comparison = section.querySelector<HTMLElement>(
      ".benefits__comparison",
    );
    const comparisonLine = section.querySelector<HTMLElement>(
      ".benefits__comparison-line",
    );
    const comparisonCard = section.querySelector<HTMLElement>(
      ".benefits__comparison-card",
    );
    const comparisonSides = section.querySelectorAll<HTMLElement>(
      ".benefits__comparison-side",
    );
    const comparisonDivider = section.querySelector<HTMLElement>(
      ".benefits__comparison-divider",
    );

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: "top 72%",
        once: true,
      },
      defaults: {
        ease: "power3.out",
      },
    });

    if (eyebrow) {
      tl.fromTo(
        eyebrow,
        {
          autoAlpha: 0,
          y: 14,
          filter: "blur(6px)",
        },
        {
          autoAlpha: 1,
          y: 0,
          filter: "blur(0px)",
          duration: 0.45,
        },
      );
    }

    if (title) {
      tl.fromTo(
        title,
        {
          autoAlpha: 0,
          y: 22,
          filter: "blur(8px)",
        },
        {
          autoAlpha: 1,
          y: 0,
          filter: "blur(0px)",
          duration: 0.65,
        },
        0.08,
      );
    }

    if (description) {
      tl.fromTo(
        description,
        {
          autoAlpha: 0,
          y: 18,
          filter: "blur(8px)",
        },
        {
          autoAlpha: 1,
          y: 0,
          filter: "blur(0px)",
          duration: 0.55,
        },
        0.16,
      );
    }

    if (grid) {
      tl.fromTo(
        grid,
        {
          autoAlpha: 0,
          y: 20,
        },
        {
          autoAlpha: 1,
          y: 0,
          duration: 0.55,
          ease: "power2.out",
        },
        0.22,
      );
    }

    if (comparison) {
      tl.fromTo(
        comparison,
        {
          autoAlpha: 0,
          y: 24,
        },
        {
          autoAlpha: 1,
          y: 0,
          duration: 0.6,
          ease: "power2.out",
        },
        0.3,
      );
    }

    if (comparisonLine) {
      tl.fromTo(
        comparisonLine,
        {
          scaleY: 0,
          transformOrigin: "top center",
          autoAlpha: 0,
        },
        {
          scaleY: 1,
          autoAlpha: 1,
          duration: 0.45,
          ease: "power2.out",
        },
        0.36,
      );
    }

    if (comparisonCard) {
      tl.fromTo(
        comparisonCard,
        {
          autoAlpha: 0,
          scale: 0.96,
          y: 16,
          filter: "blur(10px)",
        },
        {
          autoAlpha: 1,
          scale: 1,
          y: 0,
          filter: "blur(0px)",
          duration: 0.8,
          ease: "back.out(1.15)",
        },
        0.42,
      );
    }

    if (comparisonDivider) {
      tl.fromTo(
        comparisonDivider,
        {
          autoAlpha: 0,
          scale: 0.9,
        },
        {
          autoAlpha: 1,
          scale: 1,
          duration: 0.35,
          ease: "power2.out",
        },
        0.56,
      );
    }

    if (comparisonSides.length) {
      tl.fromTo(
        comparisonSides,
        {
          autoAlpha: 0,
          y: 14,
        },
        {
          autoAlpha: 1,
          y: 0,
          duration: 0.45,
          stagger: 0.08,
          ease: "power2.out",
        },
        0.52,
      );
    }
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initBenefitsSectionEntrance, {
      once: true,
    });
  } else {
    initBenefitsSectionEntrance();
  }
</script>
