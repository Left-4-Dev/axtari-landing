        <img class="stars__logo" src="/images/sections/stars/coca-cola.svg" alt="Coca-Cola" />
      </button>

      <button
        class="stars__slide"
        type="button"
        data-slide-id="brand-6"
        data-hero="/images/sections/stars/cat.png"
      >
        <img class="stars__logo" src="/images/sections/stars/samsung.svg" alt="Samsung" />
      </button>

      <button
        class="stars__slide"
        type="button"
        data-slide-id="brand-7"
        data-hero="/images/sections/stars/cat.png"
      >
        <img class="stars__logo" src="/images/sections/stars/cat.svg" alt="CAT" />
      </button>

      <button
        class="stars__slide"
        type="button"
        data-slide-id="brand-8"
        data-hero="/images/sections/stars/cat.png"
      >
        <img class="stars__logo" src="/images/sections/stars/makita.svg" alt="Makita" />
      </button>
    </div>
  </div>

  <!-- MOBILE / TABLET -->
  <div class="stars__sliders" aria-label="Marcas aliadas">
    <div class="stars__slider stars__slider--top">
      <div class="stars__track">
        <button
          class="stars__slide is-active"
          type="button"
          data-slide-id="brand-1"
          data-hero="/images/sections/stars/cat.png"
        >
          <img class="stars__logo" src="/images/sections/stars/coca-cola.svg" alt="Coca-Cola" />
        </button>

        <button
          class="stars__slide"
          type="button"
          data-slide-id="brand-2"
          data-hero="/images/sections/stars/cat.png"
        >
          <img class="stars__logo" src="/images/sections/stars/samsung.svg" alt="Samsung" />
        </button>

        <button
          class="stars__slide"
          type="button"
          data-slide-id="brand-3"
          data-hero="/images/sections/stars/cat.png"
        >
          <img class="stars__logo" src="/images/sections/stars/cat.svg" alt="CAT" />
        </button>

        <button
          class="stars__slide"
          type="button"
          data-slide-id="brand-4"
          data-hero="/images/sections/stars/cat.png"
        >
          <img class="stars__logo" src="/images/sections/stars/makita.svg" alt="Makita" />
        </button>
      </div>
    </div>

    <div class="stars__slider stars__slider--bottom">
      <div class="stars__track">
        <button
          class="stars__slide"
          type="button"
          data-slide-id="brand-5"
          data-hero="/images/sections/stars/cat.png"
        >
          <img class="stars__logo" src="/images/sections/stars/coca-cola.svg" alt="Coca-Cola" />
        </button>

        <button
          class="stars__slide"
          type="button"
          data-slide-id="brand-6"
