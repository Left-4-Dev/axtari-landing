<style>
  

  .stars__content {
    display: flex;
    flex-direction: column;
    place-content: center;
    align-items: center;
  }

  .stars__title {
    --margin-title: 0px;
  }

  /* =========================
    BASE EXTRA
  ========================= */
  .stars__sliders {
    display: none;
    width: 100%;
    margin: 1.5rem auto 0;
    flex-direction: column;
    gap: 1rem;
  }

  .stars__slider--desktop {
    display: block;
  }

  .stars__hero {
    width: 100%;
    margin: 1.5rem auto 0;
    overflow: hidden;
    border-radius: 1rem;
    aspect-ratio: 24 / 9;
    box-shadow: 0 18px 40px rgba(63, 70, 173, 0.14);

    img {
      object-fit: cover;
      transition: opacity 0.45s ease;
    }
  }

  .stars__slider {
    position: relative;
    width: 100%;
    margin: 1.5rem auto 0;
    overflow: hidden;
  }

  .stars__slider::before,
  .stars__slider::after {
    content: "";
    position: absolute;
    top: 0;
    z-index: 2;
    width: 120px;
    height: 100%;
    pointer-events: none;
    background: linear-gradient(
      to right,
      rgb(248, 247, 255) 0%,
      rgba(255, 255, 255, 0) 100%
    );
  }

  .stars__slider::before {
    left: 0;
  }

  .stars__slider::after {
    right: 0;
    transform: rotate(180deg);
  }

  .stars__track {
    display: flex;
    align-items: flex-end;
    gap: 1rem;
    width: max-content;
    will-change: transform;
  }

  .stars__slide {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
    flex: 0 0 240px;
    width: 240px;
    height: 140px;
    padding: var(--gap-sm);
    overflow: hidden;
    border: 0;
    border-radius: 1rem;
    background: linear-gradient(
      90deg,
      #a0d5fd 0%,
      #a0d3fd 10%,
      #9ea8fc 69%,
      #9d98fc 100%
    );
    cursor: pointer;
    transition:
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.35s ease;
  }

  .stars__slide::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 0;
    border-radius: inherit;
    opacity: 0;
    background: var(--text-accent);
    transition: opacity 0.35s ease;
  }

  .stars__slide:hover,
  .stars__slide.is-active {
    box-shadow: 0 22px 44px rgba(34, 40, 117, 0.22);
  }

  .stars__slide:hover::before,
  .stars__slide.is-active::before {
    opacity: 1;
  }

  .stars__logo {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 192px;
    max-height: 60px;
    height: auto;
    object-fit: contain;
  }

  /* =========================
   LARGE DESKTOP (<= 1240px)
========================= */
  @media (max-width: 1240px) {
    .stars {
      --padding-section-xl: 4rem 28px;
      --max-width-container-xl: 1120px;
    }

    .stars__content {
      padding-inline: 12px;
    }

    .stars__hero {
      margin-top: 1.25rem;
      border-radius: 0.9rem;
    }

    .stars__slider {
      margin-top: 1.25rem;
    }

    .stars__slide {
      flex: 0 0 220px;
      width: 220px;
      height: 132px;
    }

    .stars__logo {
      max-width: 176px;
      max-height: 56px;
    }

    .stars__slider::before,
    .stars__slider::after {
      width: 96px;
    }
  }

  /* =========================
   LAPTOP (<= 1024px)
========================= */
  @media (max-width: 1024px) {
    .stars {
      --padding-section-lg: 3.5rem 32px;
      --max-width-container-lg: 1000px;
    }

    .stars__content {
      padding-inline: 16px;
    }

    .stars__hero {
      aspect-ratio: 20 / 9;
      margin-top: 1.125rem;
      border-radius: 0.85rem;
    }

    .stars__slider {
      margin-top: 1.125rem;
    }

    .stars__track {
      gap: 0.875rem;
    }

    .stars__slide {
      flex: 0 0 200px;
      width: 200px;
      height: 124px;
      border-radius: 0.9rem;
    }

    .stars__logo {
      max-width: 156px;
      max-height: 52px;
    }

    .stars__slider::before,
    .stars__slider::after {
      width: 80px;
    }
  }

  /* =========================
   TABLET (<= 900px)
========================= */
  @media (max-width: 900px) {
    .stars {
      --padding-section-md: 3.25rem 36px;
    }

    .stars__content {
      padding-inline: 18px;
    }

    .stars__hero,
    .stars__slider--desktop {
      display: none;
    }

    .stars__sliders {
      display: flex;
    }

    .stars__slider {
      margin-top: 0;
    }

    .stars__track {
      gap: 0.875rem;
    }

    .stars__slide {
      flex: 0 0 190px;
      width: 190px;
      height: 112px;
      border-radius: 0.9rem;
    }

    .stars__logo {
      max-width: 144px;
      max-height: 48px;
    }

    .stars__slider::before,
    .stars__slider::after {
      width: 64px;
    }

    .stars__slider--bottom {
      opacity: 0.82;
    }
  }

  /* =========================
   MOBILE (<= 640px)
========================= */
  @media (max-width: 640px) {
    .stars {
      --padding-section-sm: 3rem 28px;
    }

    .stars__content {
      padding-inline: 14px;
    }

    .stars__sliders {
      gap: 0.875rem;
      margin-top: 1.125rem;
    }

    .stars__track {
      gap: 0.75rem;
    }

    .stars__slide {
      flex: 0 0 170px;
      width: 170px;
      height: 100px;
      padding: 0.75rem;
      border-radius: 0.8rem;
    }

    .stars__logo {
      max-width: 128px;
      max-height: 42px;
    }

    .stars__slider::before,
    .stars__slider::after {
      width: 48px;
    }
  }

  /* =========================
   SMALL MOBILE (<= 380px)
========================= */
  @media (max-width: 380px) {
    .stars {
      --padding-section-xs: 2.75rem 20px;
    }

    .stars__content {
      padding-inline: 10px;
    }

    .stars__sliders {
      gap: 0.75rem;
      margin-top: 1rem;
    }

    .stars__track {
      gap: 0.625rem;
    }

    .stars__slide {
      flex: 0 0 150px;
      width: 150px;
      height: 90px;
      padding: 0.625rem;
      border-radius: 0.75rem;
    }

    .stars__logo {
      max-width: 112px;
      max-height: 36px;
    }

    .stars__slider::before,
    .stars__slider::after {
      width: 36px;
    }
  }
</style>
