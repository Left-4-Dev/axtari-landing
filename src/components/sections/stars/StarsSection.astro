---
import StarsContent from "@components/sections/stars/StarsContent.astro";
---

<section class="stars section">
  <div class="stars__container container">
    <StarsContent />
  </div>
</section>
<style>
  

  .stars {
    background: linear-gradient(
      180deg,
      rgba(219, 214, 255, 0.6) 16%,
      rgba(219, 214, 255, 0.4) 20%,
      rgba(230, 226, 255, 0.2) 50%,
      rgba(255, 255, 255, 0) 100%
    );
    --padding-section: 4rem 0;
    text-transform: uppercase;
  }

  .stars__container {
    --max-width-container: 1200px;
  }

  /* =========================
   LARGE DESKTOP (<= 1240px)
========================= */
  @media (max-width: 1240px) {
    .stars {
      --padding-section-xl: 4rem 28px;
      --max-width-container-xl: 1120px;
    }
  }

  /* =========================
   LAPTOP (<= 1024px)
========================= */
  @media (max-width: 1024px) {
    .stars {
      --padding-section-lg: 3.5rem 32px;
      --max-width-container-lg: 1000px;
    }
  }

  /* =========================
   TABLET (<= 900px)
========================= */
  @media (max-width: 900px) {
    .stars {
      --padding-section-md: 3.25rem 36px;
    }
  }

  /* =========================
   MOBILE (<= 640px)
========================= */
  @media (max-width: 640px) {
    .stars {
      --padding-section-sm: 3rem 28px;
    }
  }

  /* =========================
   SMALL MOBILE (<= 380px)
========================= */
  @media (max-width: 380px) {
    .stars {
      --padding-section-xs: 2.75rem 20px;
    }
  }
</style>
