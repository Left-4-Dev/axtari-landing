            duration: 0.42,
            ease: "power2.out",
          },
          0.08,
        )
        .from(
          ".buyer__role",
          {
            y: 12,
            autoAlpha: 0,
            duration: 0.45,
            ease: "power2.out",
          },
          0.14,
        )
        .from(
          ".buyer__image",
          {
            y: 16,
            scale: 0.95,
            autoAlpha: 0,
            filter: "blur(10px)",
            duration: 0.75,
            ease: "back.out(1.15)",
          },
          0.18,
        )
        .from(
          ".buyer__gallery .journey-card__shape",
          {
            autoAlpha: 0,
            y: 18,
            filter: "blur(10px)",
            duration: 0.5,
            stagger: 0.08,
            ease: "power2.out",
          },
          0.16,
        )
        .from(
          ".buyer__gallery .journey-card__base",
          {
            autoAlpha: 0,
            y: 12,
            duration: 0.36,
            stagger: 0.08,
            ease: "power2.out",
          },
          0.22,
        )
        .from(
          ".buyer__gallery .journey-card__top",
          {
            autoAlpha: 0,
            y: 14,
            duration: 0.4,
            stagger: 0.08,
            ease: "power2.out",
          },
          0.26,
        )
        .from(
          ".buyer__gallery .journey-card__body",
          {
            autoAlpha: 0,
            y: 16,
            filter: "blur(8px)",
            duration: 0.45,
            stagger: 0.08,
            ease: "power2.out",
          },
          0.32,
        );

      return () => {
        galleryEl.removeEventListener("scroll", onGalleryScroll);
        window.removeEventListener("resize", onResize);
        if (rafId !== null) cancelAnimationFrame(rafId);
      };
    });
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initBuyerFunctionsGallery, {
      once: true,
    });
  } else {
    initBuyerFunctionsGallery();
  }
</script>
