---
import BuyersContent from "@components/sections/buyers/BuyersContent.astro";
---

<section class="buyer section">
  <div class="buyer__pin-wrap">
    <div class="buyer__container container">
      <BuyersContent />
    </div>
  </div>
</section>

<style>
  

  .buyer {
    --gradient-1-angle: 90deg;
    --gradient-1-stop-1-color: #a0d5fd;
    --gradient-1-stop-1-pos: 0%;
    --gradient-1-stop-2-color: #9fb7f5;
    --gradient-1-stop-2-pos: 65%;
    --gradient-1-stop-3-color: #9d98ec;
    --gradient-1-stop-3-pos: 100%;

    --padding-section: 2rem 0;
    --buyer-total-h: auto;
    overflow-x: hidden;
    overflow-y: visible;
    min-height: var(--buyer-total-h);
    text-transform: uppercase;
  }

  .buyer__pin-wrap {
    position: relative;
  }

  .buyer__container {
    --max-width-container: 100%;
  }

  /* =========================
   LARGE DESKTOP (<= 1240px)
========================= */
  @media (max-width: 1240px) {
    .buyer {
      --padding-section-xl: 2rem 0px;
      --max-width-container-xl: 1120px;
    }
  }

  /* =========================
   LAPTOP (<= 1024px)
========================= */
  @media (max-width: 1024px) {
    .buyer {
      --padding-section-lg: 3rem 0px 3.5rem;
      --max-width-container-lg: 1000px;
    }
  }

  /* =========================
   TABLET (<= 900px)
========================= */
  @media (max-width: 900px) {
    .buyer {
      --padding-section-md: 2.75rem 0px 3.25rem;
    }
  }

  /* =========================
   MOBILE (<= 640px)
========================= */
  @media (max-width: 640px) {
    .buyer {
      --padding-section-sm: 2.5rem 0px 3rem;
    }
  }

  /* =========================
   SMALL MOBILE (<= 380px)
========================= */
  @media (max-width: 380px) {
    .buyer {
      --padding-section-xs: 2.25rem 0px 2.75rem;
    }
  }
</style>
