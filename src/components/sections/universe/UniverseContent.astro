<style>
  

  .universe__content {
    display: flex;
    flex-direction: column;
    place-content: center;
    align-items: center;
    gap: 0.5rem;
  }

  .universe__title {
    --margin-title: 0px;
    --color-title: var(--text-white);
  }

  .universe__title span {
    --color-title-span: #a0d5fd;
  }

  .universe__description {
    --color-description: var(--text-white);
  }

  .universe__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-auto-rows: 280px;
    grid-auto-flow: dense;
    gap: var(--gap-md);
    margin-top: 1.5rem;
    width: 100%;
  }

  .universe__card {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    min-height: 0;
    overflow: hidden;
    border-radius: 1rem;
    background: linear-gradient(135deg, #a0d5fd 0%, #9ea8fc 60%, #9d98fc 100%);
    color: var(--text-white);
    box-shadow:
      -4px -4px 4px rgba(255, 255, 255, 0.4),
      4px 4px 4px rgba(0, 0, 0, 0.2);
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
    cursor: pointer;
    will-change: transform;
  }

  .universe__card:hover {
    transform: translateY(-4px);
    box-shadow:
      -4px -4px 8px rgba(255, 255, 255, 0.4),
      4px 4px 8px rgba(0, 0, 0, 0.2);
  }

  .universe__card.is-expanded {
    grid-row: 1 / span 2;
  }

  .universe__card.is-expanded .universe__card-cover {
    display: none;
  }

  .universe__card.is-expanded .universe__card-media {
    display: block;
  }

  .universe__card.is-expanded .universe__card-body {
    display: flex;
  }

  .universe__card-cover {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    padding-inline: 1rem;
  }

  .universe__brand {
    width: 96px;
    height: auto;
    aspect-ratio: 54 / 17;
    padding-left: 0.5rem;
  }

  .universe__card-name {
    margin: 1rem 0 0;
    font-family: "Josefin Sans", sans-serif;
    font-size: clamp(3rem, 6vw, 4.8rem);
    line-height: 0.95;
  }

  .universe__status {
    align-self: stretch;
    margin: 0;
    padding: 0.75rem 1rem;
    background: var(--text-accent);
    text-align: center;
    font-weight: 600;
    font-family: "Josefin Sans", sans-serif;
  }

  .universe__card-media {
    position: relative;
    display: none;
    width: 100%;
    height: 50%;
  }

  .universe__card-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .universe__card-badge {
    position: absolute;
    top: 50%;
    left: 50%;
    display: grid;
    place-items: center;
    width: clamp(88px, 9.5vw, 132px);
    aspect-ratio: 1 / 1;
    border-radius: 50%;
    background: #0f1530;
    color: var(--text-white);
    box-shadow: 0 10px 16px rgba(0, 0, 0, 0.25);
    transform: translate(-50%, -50%);
  }

  .universe__card-badge-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.25rem;
    font-family: "Josefin Sans", sans-serif;
  }

  .universe__card-badge-content span {
    font-size: clamp(1rem, 2vw, 1.5rem);
    font-weight: 700;
  }

  .universe__card-badge-content svg,
  .universe__card-badge-content img {
    width: 40px;
    height: auto;
  }

  .universe__card-body {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
    width: 100%;
    height: 50%;
    padding: 2.5rem 1.5rem 1.5rem 1.5rem;
    background-color: var(--bg-primary);
    text-align: center;
  }

  .universe__card-description {
    color: var(--text-black);
    font-size: var(--font-md);
    letter-spacing: 0em;
    font-weight: 400;
    line-height: 1.5em;
    text-wrap: balance;
    font-family: "Noto Sans", sans-serif;
  }

  .universe__button {
    align-self: self-end;
    border: 0;
    border-radius: 0.625rem;
    padding: 0.625rem 2.5rem;
    background: var(--text-accent);
    color: var(--text-white);
    font-family: "Exo", sans-serif;
    font-size: clamp(0.8rem, 1.4vw, 1rem);
    font-weight: 600;
    text-transform: uppercase;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      transform 0.2s ease;
  }

  .universe__button:hover {
    background: #3f4ddb;
    transform: translateY(-1px);
  }

  /* =========================
   LARGE DESKTOP (<= 1240px)
========================= */
  @media (max-width: 1240px) {
    .universe {
      --padding-section-xl: 4rem 28px;
      --max-width-container-xl: 1120px;
    }

    .universe__content {
      padding-inline: 12px;
    }

    .universe__grid {
      grid-auto-rows: 250px;
      gap: 1rem;
      margin-top: 1.25rem;
    }

    .universe__card-name {
      font-size: clamp(2.6rem, 5vw, 4rem);
    }

    .universe__card-body {
      gap: 1.5rem;
      padding: 2rem 1.25rem 1.25rem;
    }
  }

  /* =========================
   LAPTOP (<= 1024px)
========================= */
  @media (max-width: 1024px) {
    .universe {
      --padding-section-lg: 3.5rem 32px;
      --max-width-container-lg: 1000px;
    }

    .universe__content {
      padding-inline: 16px;
    }

    .universe__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-auto-rows: 240px;
      gap: 1rem;
    }

    .universe__card.is-expanded {
      grid-row: span 2;
    }

    .universe__card-name {
      font-size: clamp(2.3rem, 6vw, 3.5rem);
    }

    .universe__brand {
      width: 84px;
    }

    .universe__card-body {
      gap: 1.25rem;
      padding: 1.75rem 1.125rem 1.125rem;
    }

    .universe__card-description {
      font-size: 0.92rem;
    }

    .universe__button {
      padding: 0.6rem 2rem;
    }
  }

  /* =========================
   TABLET (<= 900px)
========================= */
  @media (max-width: 900px) {
    .universe {
      --padding-section-md: 3.25rem 36px;
    }

    .universe__content {
      padding-inline: 18px;
      gap: 0.875rem;
    }

    .universe__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-auto-rows: 220px;
      gap: 0.875rem;
    }

    .universe__card {
      border-radius: 0.875rem;
    }

    .universe__card-name {
      margin-top: 0.75rem;
      font-size: clamp(2rem, 6vw, 3rem);
    }

    .universe__status {
      padding: 0.65rem 0.875rem;
      font-size: 0.85rem;
    }

    .universe__card-badge {
      width: 100px;
    }

    .universe__card-badge-content span {
      font-size: 1.1rem;
    }

    .universe__card-badge-content svg,
    .universe__card-badge-content img {
      width: 34px;
    }

    .universe__card-body {
      gap: 1rem;
      padding: 1.5rem 1rem 1rem;
    }

    .universe__card-description {
      font-size: 0.86rem;
      line-height: 1.42em;
    }

    .universe__button {
      padding: 0.55rem 1.75rem;
      font-size: 0.85rem;
    }
  }

  /* =========================
   MOBILE (<= 640px)
========================= */
  @media (max-width: 640px) {
    .universe {
      --padding-section-sm: 3rem 28px;
    }

    .universe__content {
      padding-inline: 14px;
      gap: 0.75rem;
    }

    .universe__grid {
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
      gap: 0.875rem;
      margin-top: 1rem;
    }

    .universe__card,
    .universe__card.is-expanded {
      grid-row: auto;
      min-height: 220px;
    }

    .universe__card-name {
      font-size: clamp(2rem, 10vw, 3rem);
    }

    .universe__brand {
      width: 76px;
    }

    .universe__status {
      font-size: 0.8rem;
    }

    .universe__card-badge {
      width: 88px;
    }

    .universe__card-badge-content span {
      font-size: 1rem;
    }

    .universe__card-badge-content svg,
    .universe__card-badge-content img {
      width: 30px;
    }

    .universe__card-body {
      gap: 0.875rem;
      padding: 1.25rem 0.9rem 0.9rem;
    }

    .universe__card-description {
      font-size: 0.8rem;
      line-height: 1.38em;
    }

    .universe__button {
      align-self: center;
      width: 100%;
      max-width: 180px;
      padding: 0.625rem 1.25rem;
      font-size: 0.82rem;
    }
