---
const navLinks = [
  { label: "Inicio", href: "#hero" },
  { label: "Categorías", href: "#universe" },
  { label: "Nosotros", href: "#about" },
  { label: "Eventos", href: "#events" },
  { label: "Contacto", href: "#contact" },
];
---

<header class="navbar" id="navbar">
  <div class="navbar__inner">
    <a href="/" class="navbar__brand" aria-label="Axtari home">
      <span class="navbar__brand-mark" aria-hidden="true">
        <span class="navbar__brand-star"></span>
      </span>
      <span class="navbar__brand-text">AXTERI</span>
    </a>

    <nav class="navbar__desktop" aria-label="Principal">
      <ul class="navbar__menu">
        {
          navLinks.map((link) => (
            <li>
              <a href={link.href} class="navbar__link">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <div class="navbar__actions">
      <button
        class="navbar__theme-toggle"
        type="button"
        aria-label="Cambiar tema"
      >
        <span class="navbar__theme-track">
          <span class="navbar__theme-thumb">
            <span class="navbar__theme-moon"></span>
          </span>
        </span>
      </button>

      <button
        class="navbar__mobile-toggle"
        id="mobileMenuToggle"
        type="button"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobileMenu"
      >
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <div class="navbar__mobile-panel" id="mobileMenu">
    <nav class="navbar__mobile-nav" aria-label="Menú móvil">
      <ul class="navbar__mobile-list">
        {
          navLinks.map((link) => (
            <li>
              <a href={link.href} class="navbar__mobile-link">
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<script>
  const navbar = document.getElementById("navbar");
  const mobileToggle = document.getElementById("mobileMenuToggle");
  const mobileMenu = document.getElementById("mobileMenu");

  let lastScrollY = window.scrollY;

  const updateNavbarOnScroll = () => {
    const currentScrollY = window.scrollY;

    if (!navbar) return;

    if (currentScrollY > 20) {
      navbar.classList.add("is-scrolled");
    } else {
      navbar.classList.remove("is-scrolled");
    }

    if (currentScrollY > lastScrollY && currentScrollY > 120) {
      navbar.classList.add("is-hidden");
    } else {
      navbar.classList.remove("is-hidden");
    }

    lastScrollY = currentScrollY;
  };

  const closeMobileMenu = () => {
    if (!mobileToggle || !mobileMenu) return;
    mobileToggle.setAttribute("aria-expanded", "false");
    mobileMenu.classList.remove("is-open");
    mobileToggle.classList.remove("is-active");
  };

  const toggleMobileMenu = () => {
    if (!mobileToggle || !mobileMenu) return;

    const isExpanded = mobileToggle.getAttribute("aria-expanded") === "true";
    mobileToggle.setAttribute("aria-expanded", String(!isExpanded));
    mobileMenu.classList.toggle("is-open");
    mobileToggle.classList.toggle("is-active");
  };

  mobileToggle?.addEventListener("click", toggleMobileMenu);

  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", closeMobileMenu);
  });

  window.addEventListener("scroll", updateNavbarOnScroll, { passive: true });
  updateNavbarOnScroll();
</script>

<style>
  .navbar {
    --nav-text: #2f3448;
    --nav-text-soft: #5d647d;
    --nav-accent: #7379ff;
    --nav-accent-soft: rgba(111, 118, 255, 0.12);
    --nav-surface: rgba(255, 255, 255, 0.3);
    --nav-surface-strong: rgba(255, 255, 255, 0.46);
    --nav-border: rgba(255, 255, 255, 0.38);
    --nav-shadow: rgba(109, 122, 255, 0.1);

    position: fixed;
    top: 18px;
    left: 50%;
    transform: translateX(-50%) translateY(0);
    width: min(1280px, calc(100% - 32px));
    z-index: 1000;
    transition:
      transform 0.32s ease,
      opacity 0.32s ease;
  }

  .navbar.is-hidden {
    transform: translateX(-50%) translateY(-120%);
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    min-height: 64px;
    padding: 10px 14px 10px 18px;

    border-radius: 999px;
    background: var(--nav-surface);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border: 1px solid var(--nav-border);
    box-shadow:
      0 10px 30px var(--nav-shadow),
      0 18px 40px rgba(146, 157, 255, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.5);

    transition:
      min-height 0.28s ease,
      padding 0.28s ease,
      background 0.28s ease,
      box-shadow 0.28s ease,
      backdrop-filter 0.28s ease;
  }

  .navbar.is-scrolled .navbar__inner {
    min-height: 68px;
    padding: 10px 14px 10px 18px;
    background: var(--nav-surface-strong);
    backdrop-filter: blur(22px);
    -webkit-backdrop-filter: blur(22px);
    box-shadow:
      0 12px 32px rgba(109, 122, 255, 0.14),
      0 24px 50px rgba(146, 157, 255, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.58);
  }

  .navbar__brand {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .navbar__brand-mark {
    width: 34px;
    height: 34px;
    display: inline-grid;
    place-items: center;
  }

  .navbar__brand-star {
    width: 28px;
    height: 28px;
    background: var(--nav-text);
    clip-path: polygon(
      50% 0%,
      58% 38%,
      100% 50%,
      58% 62%,
      50% 100%,
      42% 62%,
      0% 50%,
      42% 38%
    );
    opacity: 0.96;
  }

  .navbar__brand-text {
    color: var(--nav-text);
    font-size: 1.5rem;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .navbar__desktop {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1;
  }

  .navbar__menu {
    display: flex;
    align-items: center;
    gap: 8px;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .navbar__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 40px;
    padding: 0 14px;
    border-radius: 999px;
    text-decoration: none;

    color: var(--nav-text);
    font-size: 14px;
    font-weight: 500;
    line-height: 1.2em;
    letter-spacing: 0em;
    text-transform: uppercase;

    transition:
      color 0.22s ease,
      background 0.22s ease,
      transform 0.22s ease,
      box-shadow 0.22s ease;
  }

  .navbar__link:hover {
    color: var(--nav-accent);
    background: rgba(255, 255, 255, 0.28);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4);
  }

  .navbar__actions {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-shrink: 0;
  }

  .navbar__theme-toggle {
    border: 0;
    background: transparent;
    padding: 0;
    cursor: pointer;
    display: inline-flex;
  }

  .navbar__theme-track {
    width: 64px;
    height: 38px;
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    padding: 4px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.46);
    box-shadow:
      0 8px 20px rgba(109, 122, 255, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.58);
  }

  .navbar__theme-thumb {
    width: 28px;
    height: 28px;
    border-radius: 999px;
    background: linear-gradient(180deg, #3b4050 0%, #2f3448 100%);
    box-shadow:
      0 6px 14px rgba(0, 0, 0, 0.14),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
    display: grid;
    place-items: center;
  }

  .navbar__theme-moon {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: white;
    position: relative;
  }

  .navbar__theme-moon::after {
    content: "";
    position: absolute;
    top: -1px;
    right: -2px;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: #3b4050;
  }

  .navbar__mobile-toggle {
    display: none;
    width: 46px;
    height: 46px;
    border: 1px solid rgba(255, 255, 255, 0.42);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.34);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    cursor: pointer;
    padding: 0;
    position: relative;
    box-shadow:
      0 8px 20px rgba(109, 122, 255, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.5);
  }

  .navbar__mobile-toggle span {
    position: absolute;
    left: 50%;
    width: 18px;
    height: 2px;
    border-radius: 999px;
    background: var(--nav-text);
    transform: translateX(-50%);
    transition:
      transform 0.24s ease,
      top 0.24s ease,
      opacity 0.24s ease;
  }

  .navbar__mobile-toggle span:first-child {
    top: 17px;
  }

  .navbar__mobile-toggle span:last-child {
    top: 25px;
  }

  .navbar__mobile-toggle.is-active span:first-child {
    top: 21px;
    transform: translateX(-50%) rotate(45deg);
  }

  .navbar__mobile-toggle.is-active span:last-child {
    top: 21px;
    transform: translateX(-50%) rotate(-45deg);
  }

  .navbar__mobile-panel {
    display: none;
    margin-top: 10px;
    padding: 14px;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.34);
    backdrop-filter: blur(22px);
    -webkit-backdrop-filter: blur(22px);
    border: 1px solid rgba(255, 255, 255, 0.42);
    box-shadow:
      0 10px 30px rgba(109, 122, 255, 0.1),
      0 18px 40px rgba(146, 157, 255, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.55);
  }

  .navbar__mobile-panel.is-open {
    display: block;
  }

  .navbar__mobile-nav {
    width: 100%;
  }

  .navbar__mobile-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 8px;
  }

  .navbar__mobile-link {
    min-height: 50px;
    display: flex;
    align-items: center;
    padding: 0 16px;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.22);
    color: var(--nav-text);
    text-decoration: none;
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: -0.02em;
    transition:
      background 0.22s ease,
      color 0.22s ease,
      transform 0.22s ease;
  }

  .navbar__mobile-link:hover {
    background: rgba(255, 255, 255, 0.38);
    color: var(--nav-accent);
  }

  /* =========================
   LARGE DESKTOP (<= 1240px)
========================= */
  @media (max-width: 1240px) {
    .navbar {
      width: min(1200px, calc(100% - 32px));
    }

    .navbar__inner {
      padding: 10px 12px 10px 16px;
    }

    .navbar__menu {
      gap: 6px;
    }

    .navbar__link {
      padding: 0 12px;
      font-size: 0.93rem;
    }
  }

  /* =========================
   LAPTOP (<= 1024px)
========================= */
  @media (max-width: 1024px) {
    .navbar {
      width: min(100%, calc(100% - 28px));
    }

    .navbar__brand-text {
      font-size: 1.65rem;
    }

    .navbar__link {
      padding: 0 10px;
      font-size: 0.9rem;
    }

    .navbar__theme-track {
      width: 58px;
      height: 34px;
    }

    .navbar__theme-thumb {
      width: 26px;
      height: 26px;
    }
  }

  /* =========================
   TABLET (<= 900px)
========================= */
  @media (max-width: 900px) {
    .navbar {
      top: 14px;
      width: min(100%, calc(100% - 24px));
    }

    .navbar__inner {
      min-height: 66px;
      padding: 10px 12px;
    }

    .navbar__desktop {
      display: none;
    }

    .navbar__mobile-toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .navbar__brand-text {
      font-size: 1.5rem;
    }

    .navbar__brand-mark {
      width: 28px;
      height: 28px;
    }

    .navbar__brand-star {
      width: 24px;
      height: 24px;
    }
  }

  /* =========================
   MOBILE (<= 640px)
========================= */
  @media (max-width: 640px) {
    .navbar {
      top: 10px;
      width: min(100%, calc(100% - 20px));
    }

    .navbar__inner {
      min-height: 62px;
      padding: 8px 10px;
      border-radius: 999px;
    }

    .navbar__actions {
      gap: 6px;
    }

    .navbar__mobile-toggle {
      width: 42px;
      height: 42px;
    }

    .navbar__theme-track {
      width: 52px;
      height: 32px;
    }

    .navbar__theme-thumb {
      width: 24px;
      height: 24px;
    }

    .navbar__brand-text {
      font-size: 1.35rem;
    }
  }

  /* =========================
   SMALL MOBILE (<= 380px)
========================= */
  @media (max-width: 380px) {
    .navbar {
      width: min(100%, calc(100% - 16px));
    }

    .navbar__inner {
      min-height: 58px;
      padding: 8px;
    }

    .navbar__brand-text {
      font-size: 1.2rem;
    }

    .navbar__mobile-toggle {
      width: 38px;
      height: 38px;
    }

    .navbar__theme-track {
      width: 48px;
      height: 30px;
    }

    .navbar__theme-thumb {
      width: 22px;
      height: 22px;
    }
  }
</style>
