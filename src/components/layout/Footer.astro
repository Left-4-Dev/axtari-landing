---

<footer class="footer">
  <div class="footer__bg">
    <div class="footer__gradient"></div>
    <div class="footer__image">
      <img src={sectionImage("hero", "hero__background.webp")} alt="" />
    </div>
  </div>
  <div class="footer__inner">
    <div class="footer__top">
      <div class="footer__left">
        <!-- <a href="/" class="footer__logo" aria-label="Axtari home">
          <span class="footer__logo-mark" aria-hidden="true">
            <span class="footer__logo-slash"></span>
            <span class="footer__logo-slash"></span>
            <span class="footer__logo-dot"></span>
          </span>
          <span class="footer__logo-text">Axtari</span>
        </a> -->
        <div class="footer__logo">
          <span class="footer__logo-mark" aria-hidden="true">
            <img src={iconBrand("Logo.svg")} alt="Ícono Axteri" />
          </span>
          <span class="footer__logo-text">
            <img src={iconBrand("Text_logo.svg")} alt="Axteri" />
          </span>
        </div>
        <section class="footer__newsletter" aria-label="Newsletter">
          <h2 class="footer__title">
            Decisiones más inteligentes empiezan aquí
          </h2>
          <p class="footer__description">
            Accede a proveedores, información y oportunidades para tomar
            decisiones de compra más rápidas y estratégicas.
          </p>

          <form class="footer__form" action="#" method="post">
            <label class="sr-only" for="footer-email">Ingresa tu correo</label>
            <input
              id="footer-email"
              name="email"
              type="email"
              class="footer__input"
              placeholder="Enter your email..."
              autocomplete="email"
            />
            <button type="submit" class="footer__submit" aria-label="Submit">
              <span aria-hidden="true">→</span>
            </button>
          </form>
        </section>
      </div>

      <div class="footer__right">
        <!-- <nav class="footer__column" aria-label="Company">
          <h3 class="footer__heading">Company</h3>
          <ul class="footer__list">
            {
              companyLinks.map((link) => (
                <li>
                  <a class="footer__link" href={link.href}>
                    <span>{link.label}</span>

                    {link.dot && (
                      <span class="footer__dot" aria-hidden="true" />
                    )}

                    {link.badge && (
                      <span class="footer__badge" aria-hidden="true">
                        {link.badge}
                      </span>
                    )}
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>

        <nav class="footer__column" aria-label="Socials">
          <h3 class="footer__heading">Socials</h3>
          <ul class="footer__list">
            {
              socialLinks.map((link) => (
                <li>
                  <a class="footer__link footer__link--social" href={link.href}>
                    <span class="footer__social-icon" aria-hidden="true">
                      {link.icon}
                    </span>
                    <span>{link.label}</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </nav> -->

        <!-- EXPLORAR -->
        <nav class="footer__column" aria-label="Explorar">
          <h3 class="footer__heading">Explorar</h3>
          <ul class="footer__list">
            {
              explorarLinks.map((link) => (
                <li>
                  <a class="footer__link" href={link.href}>
                    <span>{link.label}</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>

        <!-- EMPRESA -->
        <nav class="footer__column" aria-label="Empresa">
          <h3 class="footer__heading">Empresa</h3>
          <ul class="footer__list">
            {
              empresaLinks.map((link) => (
                <li>
                  <a class="footer__link" href={link.href}>
                    <span>{link.label}</span>
                  </a>
                </li>
              ))
            }
          </ul>
        </nav>

        <!-- EVENTOS -->
        <nav class="footer__column" aria-label="Eventos">
          <h3 class="footer__heading">Eventos</h3>
