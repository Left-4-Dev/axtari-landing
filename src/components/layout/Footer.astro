        <!-- CONTACTO -->
        <div class="footer__column" aria-label="Contacto">
          <h3 class="footer__heading">Contacto</h3>

          <ul class="footer__list">
            <li>
              <a class="footer__link" href="tel:+51934923404">
                +51 934 923 404
              </a>
            </li>
          </ul>

          <ul class="footer__list">
            {
              socialLinks.map((link) => (
                <li>
                  <a class="footer__link footer__link--social" href={link.href}>
