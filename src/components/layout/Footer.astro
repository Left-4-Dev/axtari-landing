import { sectionImage, iconBrand, uiImage } from "@lib/utils/asset.utils";

const companyLinks = [
  { label: "Contact us", href: "#" },
  { label: "About us", href: "#" },
  { label: "Projects", href: "#", dot: true },
  { label: "Career", href: "#", badge: "Hiring" },
  { label: "Blog", href: "#", badge: "6" },
];

