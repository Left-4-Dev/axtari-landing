    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.25rem;
    color: var(--card-bullet);
  }

  .journey-card__list span {
    font-size: 0.75rem;
    line-height: 1.5em;
    letter-spacing: 0em;
    color: var(--card-text);
    text-transform: uppercase;
    padding-left: 0.75rem;
    font-weight: 300;
    font-family: "Noto Sans", sans-serif;
  } */

  /* =========================
   LARGE DESKTOP (<= 1240px)
========================= */
  @media (max-width: 1240px) {
    .journey-card {
      flex: 0 0 300px;
      width: 300px;
    }
  }

  /* =========================
   LAPTOP (<= 1024px)
========================= */
  @media (max-width: 1024px) {
    .journey-card {
      flex: 0 0 280px;
      width: 280px;
    }
  }

  /* =========================
   TABLET (<= 900px)
========================= */
  @media (max-width: 900px) {
    .journey-card {
      flex: 0 0 260px;
      width: 260px;
      aspect-ratio: 0.55;
    }

    .journey-card__top {
      padding: 1.25rem;
    }

    .journey-card__body {
      padding: 1.75rem 1.25rem;
    }

    .journey-card__title {
      margin-bottom: 1.25rem;
      font-size: 0.95rem;
    }

    .journey-card__list {
      gap: 1rem;
    }

    .journey-card__item {
      gap: 0.625rem;
    }

    .journey-card__sublist {
      gap: 0.35rem;
    }

    .journey-card__label {
      font-size: 0.7rem;
    }

    .journey-card__subitem {
      font-size: 0.72rem;
    }

    .journey-card__subitem::before {
      top: 9px;
    }
  }

  /* =========================
   MOBILE (<= 640px)
========================= */
  @media (max-width: 640px) {
    .journey-card {
      flex: 0 0 240px;
      width: 240px;
    }

    .journey-card__number {
      font-size: 3rem;
    }

    .journey-card__icon-wrap {
      width: 3.4rem;
      height: 3.4rem;
      padding: 0.85rem;
    }

    .journey-card__top {
      padding: 1.125rem;
    }

    .journey-card__body {
      padding: 1.5rem 1.125rem;
    }

    .journey-card__title {
      margin-bottom: 1.125rem;
      font-size: 0.92rem;
    }

    .journey-card__list {
      gap: 0.9rem;
    }

    .journey-card__item {
      gap: 0.55rem;
    }

    .journey-card__sublist {
      gap: 0.3rem;
      padding-left: 0.65rem;
    }

    .journey-card__label {
      font-size: 0.68rem;
      padding-left: 0.7rem;
    }

    .journey-card__label::before {
      font-size: 1.05rem;
    }

    .journey-card__subitem {
      font-size: 0.7rem;
      padding-left: 0.7rem;
    }

    .journey-card__subitem::before {
      width: 3.5px;
      height: 3.5px;
      top: 9px;
    }
  }

  /* =========================
   SMALL MOBILE (<= 380px)
========================= */
  @media (max-width: 380px) {
    .journey-card {
      flex: 0 0 220px;
      width: 220px;
    }

    .journey-card__number {
      font-size: 2.6rem;
    }

    .journey-card__icon-wrap {
      width: 3rem;
      height: 3rem;
      padding: 0.75rem;
    }

    .journey-card__base {
      height: 20px;
      bottom: -20.5px;
    }

    .journey-card__top {
      padding: 1rem;
    }

    .journey-card__body {
      padding: 1.35rem 1rem;
    }

    .journey-card__title {
      font-size: 0.85rem;
      margin-bottom: 1rem;
    }

    .journey-card__list {
      gap: 0.8rem;
    }

    .journey-card__item {
      gap: 0.5rem;
    }

    .journey-card__sublist {
      gap: 0.25rem;
      padding-left: 0.6rem;
    }

    .journey-card__label {
      font-size: 0.6rem;
      padding-left: 0.65rem;
    }

    .journey-card__label::before {
      font-size: 0.95rem;
    }

    .journey-card__subitem {
      font-size: 0.65rem;
      padding-left: 0.65rem;
    }

    .journey-card__subitem::before {
      width: 3px;
      height: 3px;
      top: 8px;
      left: 2px;
    }
  }
</style>
