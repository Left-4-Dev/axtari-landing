---
interface Props {
  text: string;
  align?: "left" | "center" | "right";
}
const { text, align = "left" } = Astro.props;
---

<span class={`eyebrow eyebrow--${align}`}>
  {text}
</span>

<style>
  
  .eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0 16px;
    min-height: 36px;
    border-radius: 999px;
    color: var(--text-accent);
    background: rgba(111, 118, 255, 0.08);
    font-size: 0.875rem;
    line-height: 1em;
    font-weight: 500;
    letter-spacing: 0em;
  }

  .eyebrow--left {
    text-align: left;
  }

  .eyebrow--center {
    text-align: center;
  }

  .eyebrow--right {
    text-align: right;
  }

  /* =========================
   LARGE DESKTOP (<= 1240px)
========================= */
  @media (max-width: 1240px) {
    .eyebrow {
      min-height: 35px;
      padding: 0 15px;
      font-size: 0.85rem;
    }
  }

  /* =========================
   LAPTOP (<= 1024px)
========================= */
  @media (max-width: 1024px) {
    .eyebrow {
      min-height: 34px;
      padding: 0 14px;
      font-size: 0.82rem;
    }
  }

  /* =========================
   TABLET (<= 900px)
========================= */
  @media (max-width: 900px) {
    .eyebrow {
      min-height: 33px;
      padding: 0 13px;
      font-size: 0.8rem;
    }
  }

  /* =========================
   MOBILE (<= 640px)
========================= */
  @media (max-width: 640px) {
    .eyebrow {
      min-height: 32px;
      padding: 0 12px;
      font-size: 0.76rem;
    }
  }

  /* =========================
   SMALL MOBILE (<= 380px)
========================= */
  @media (max-width: 380px) {
    .eyebrow {
      min-height: 30px;
      padding: 0 10px;
      font-size: 0.72rem;
    }
  }
</style>
